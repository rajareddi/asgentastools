# Environment Configuration Template
# Copy this to .env and fill in your values

# ============================================
# REQUIRED - API Configuration
# ============================================

# Your OpenRouter API Key (get from https://openrouter.ai/)
OPENROUTER_API_KEY=sk-or-your-api-key-here

# ============================================
# OPTIONAL - Server Configuration
# ============================================

# API Server host (default: 0.0.0.0)
HOST=0.0.0.0

# API Server port (default: 8000)
PORT=8000

# Debug mode (default: False)
DEBUG=False

# Python unbuffered output (for Docker, default: 1)
PYTHONUNBUFFERED=1

# ============================================
# OPTIONAL - Application Configuration
# ============================================

# Default model for OpenRouter (leave empty for default)
# Available models at https://openrouter.ai/models
OPENROUTER_MODEL=

# Maximum agent turns (default: 5)
MAX_TURNS=5

# Request timeout in seconds (default: 300)
REQUEST_TIMEOUT=300

# ============================================
# OPTIONAL - Monitoring & Logging
# ============================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable request logging (default: True)
LOG_REQUESTS=True

# ============================================
# OPTIONAL - Security
# ============================================

# Enable HTTPS (when using domain, default: False)
USE_HTTPS=False

# Domain name (for SSL certificates)
DOMAIN_NAME=

# API Key for authentication (optional, leave empty for public)
API_AUTH_KEY=

# ============================================
# OPTIONAL - Cloud Deployment
# ============================================

# For AWS
AWS_REGION=us-east-1
AWS_INSTANCE_TYPE=t3.medium

# For GCP
GCP_PROJECT_ID=
GCP_REGION=us-central1

# For Azure
AZURE_RESOURCE_GROUP=
AZURE_REGION=eastus

# ============================================
# OPTIONAL - Database (if adding persistence)
# ============================================

# DATABASE_URL=postgresql://user:password@localhost/dbname

# ============================================
# OPTIONAL - OpenTelemetry / Opik Tracing
# ============================================

# Enable OpenTelemetry tracing (default: true)
OTEL_ENABLED=true

# OTLP HTTP endpoint for traces (Opik self-hosted server)
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:5173/api/v1/private/otel/v1/traces

# Opik authorization token (if required)
OPIK_AUTHORIZATION=

# Opik workspace name (default: default)
OPIK_WORKSPACE=default

# Opik project name (default: agent-service)
OPIK_PROJECT=agent-service

# Service name for telemetry (default: python-agent-service)
OTEL_SERVICE_NAME=python-agent-service

# Enable console exporter for debugging (default: false)
OTEL_CONSOLE_EXPORTER=false

# Environment name (development, staging, production)
ENVIRONMENT=development

# ============================================
# Notes:
# ============================================
# 1. Never commit this file if filled with real values
# 2. Use strong, unique API keys
# 3. Rotate keys regularly
# 4. Use different keys for dev/staging/production
# 5. Store secrets in cloud provider's secret manager in production

